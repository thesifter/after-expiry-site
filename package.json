{
  "name": "after-expiry-site",
  "version": "0.1.0",
  "private": true,
  "description": "Static prototype website for After Expiry.",
  "scripts": {
    "serve": "python3 -m http.server 8080",
    "lint": "npm run lint:html && npm run lint:css && npm run format:check",
    "lint:html": "htmlhint index.html about.html",
    "lint:css": "stylelint \"assets/css/**/*.css\"",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "htmlhint": "^1.1.4",
    "prettier": "^3.3.3",
    "stylelint": "^16.8.1",
    "stylelint-config-standard": "^36.0.1"
  }
}
